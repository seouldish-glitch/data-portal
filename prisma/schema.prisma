generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model SportForm {
  id                        String   @id @default(auto()) @map("_id") @db.ObjectId
  name                      String
  micName                   String
  micContact                String
  headCoachName             String
  assistantCoaches          String[]
  captainName               String
  captainContact            String
  viceCaptainName           String
  ageGroupCaptains          String[]
  seniorSquadRoster         String // E.g., JSON string or long text mapping names to positions
  yearOfInception           String
  founder                   String?
  firstMic                  String?
  firstCoach                String?
  firstCaptain              String?
  internationalAchievements String
  nationalAchievements      String
  provincialAchievements    String
  annualEncounters          String
  nationalCaps              String[]
  mediaLinks                String[] // URLs for logos, photos, socials
  logoUrl                   String?
  groupPhotoUrl             String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model ClubSocietyForm {
  id                        String   @id @default(auto()) @map("_id") @db.ObjectId
  name                      String
  micName                   String
  micContact                String
  presidentName             String
  presidentContact          String
  secretaryName             String
  treasurerName             String
  otherBoardMembers         String[]
  activeMembersCount        Int
  yearOfInception           String
  founder                   String?
  firstMic                  String?
  firstPresident            String?
  objectiveMotto            String
  majorProjects             String[]
  internationalAchievements String
  nationalAchievements      String
  provincialAchievements    String
  notableAlumni             String[]
  socialMediaLinks          String[]
  mediaUploads              String[] // URLs to PNGs, photos
  logoUrl                   String?
  groupPhotoUrl             String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model PrefectsGuildForm {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  micName                 String
  micContact              String
  headPrefectName         String
  headPrefectContact      String
  deputyHeadPrefects      String[]
  seniorPrefectsCount     Int
  seniorPrefectsList      String[]
  secondYearPrefectsCount Int
  juniorPrefectsCount     Int
  firstHeadPrefect        String
  yearOfEstablishment     String
  notablePastHeadPrefects String[]
  majorAnnualEvents       String[]
  coreDutiesMission       String
  badgeLogoUrl            String?
  officialPhotos          String[]
  socialMediaLinks        String[]
  logoUrl                 String?
  groupPhotoUrl           String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model AcademicAchievementForm {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  stream             String // e.g., Science, Mathematics, Commerce, Arts, Tech
  sectionalHeadName  String
  totalStudents      Int
  topPerformingClass String
  passRates3Year     String?
  topAchievers       String // e.g., JSON or formatted text
  notableMilestones  String
  subjectHighlights  String
  notableAlumni      String[]
  officialPhotos     String[]
  logoUrl            String?
  groupPhotoUrl      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model HouseForm {
  id                       String   @id @default(auto()) @map("_id") @db.ObjectId
  houseName                String // Camillus / Cassian / Luke / Claude
  level                    String // UPPER or PRIMARY
  chiefHouseMaster         String
  houseCaptain             String
  viceCaptain              String // Vice-Captain for Upper, Assistant for Primary
  housePrefects            String[]
  motto                    String?
  historyOrigin            String? // Upper only
  athleticMeetAchievements String
  totalActiveMembers       Int
  sportingHighlights       String? // Primary only
  houseFlagUrl             String?
  actionPhotos             String[]
  notableAlumni            String[] // Upper only
  specialShields           String? // Upper only
  cheerLyrics              String?
  primaryActivities        String? // Primary only
  primaryAwards            String? // Primary only
  primaryContact           String? // Primary only
  socialMediaLinks         String[]
  logoUrl                  String?
  groupPhotoUrl            String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

